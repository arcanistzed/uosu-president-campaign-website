---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("pages.notFound.title")} description={t("pages.notFound.description")}>
	<section class="not-found poster-band">
		<h1>{t("pages.notFound.heading")}</h1>
		<p>{t("pages.notFound.body")}</p>
		<a href={localePath("/", lang)} class="back-link">{t("buttons.backHome")}</a>
	</section>
</Layout>

<style>
	.not-found {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-10) var(--space-5);
		text-align: center;
	}

	.not-found h1 {
		font-size: clamp(4rem, 10vw, 8rem);
		font-weight: 800;
		color: var(--color-muted);
		line-height: 1;
		margin-bottom: var(--space-4);
	}

	.not-found p {
		font-size: 1.125rem;
		color: var(--color-muted);
		margin: 0 auto var(--space-6);
	}

	.back-link {
		font-weight: 600;
	}
</style>
