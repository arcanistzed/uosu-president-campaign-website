---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

interface InvolvedCard {
	icon: string;
	title: string;
	body: string;
	cta?: string;
}

interface ContactItem {
	label: string;
	value: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = t<InvolvedCard[]>("pages.getInvolved.cards");
const contacts = t<ContactItem[]>("pages.getInvolved.contacts");
---

<Layout title={t("pages.getInvolved.title")} description={t("pages.getInvolved.description")}>
	<section class="involve-page">
		<div class="involve-header poster-band">
			<h1>{t("pages.getInvolved.heading")}</h1>
			<p class="involve-lead">{t("pages.getInvolved.lead")}</p>
		</div>

		<div class="ways-grid">
			{
				cards.map((card, i) => (
					<article class="way-card">
						<span class="way-icon" aria-hidden="true">{card.icon}</span>
						<h2>{card.title}</h2>
						<p>{card.body}</p>
						{
							i === 1 && (
								<a
									href="mailto:vote@danielthorp.com?subject=I want to volunteer"
									class="btn btn-primary">{card.cta}</a
								>
							)
						}
						{
							i === 2 && (
								<a href={localePath("/vote/", lang)} class="btn btn-secondary"
									>{card.cta}</a
								>
							)
						}
					</article>
				))
			}
		</div>

		<div class="contact-section poster-band">
			<h2>{t("pages.getInvolved.contactHeading")}</h2>
			<div class="contact-grid">
				{contacts.map((item, i) => (
					<div class="contact-item">
						<h3>{item.label}</h3>
						{
							i === 0 && <a href="mailto:vote@danielthorp.com">{item.value}</a>
						}
						{
							i === 1 && (
								<a
									href="https://instagram.com/daniel.thorp.seuo.uosu"
									rel="noopener noreferrer">{item.value}</a
								>
							)
						}
						{
							i === 2 && (
								<a href="https://danielthorp.com" rel="noopener noreferrer">{item.value}</a>
							)
						}
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	.involve-page {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-8) var(--space-5) var(--space-9);
	}

	.involve-header {
		margin-bottom: var(--space-8);
	}

	.involve-header h1 {
		margin-bottom: var(--space-3);
	}

	.involve-lead {
		font-size: 1.125rem;
		color: var(--color-muted);
		max-width: 56ch;
		line-height: 1.6;
	}

	.ways-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
		gap: var(--space-5);
		margin-bottom: var(--space-8);
	}

	.way-card {
		padding: var(--space-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-2);
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.way-icon {
		font-size: 2rem;
	}

	.way-card h2 {
		font-size: 1.25rem;
	}

	.way-card p {
		font-size: 0.9375rem;
		color: var(--color-muted);
		line-height: 1.65;
		flex: 1;
	}

	.contact-section {
		margin-bottom: var(--space-7);
		padding-bottom: var(--space-7);
		border-bottom: 1px solid var(--color-border);
	}

	.contact-section.poster-band {
		padding: var(--space-6) var(--space-5);
		border-bottom: none;
	}

	.contact-section h2 {
		margin-bottom: var(--space-5);
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr));
		gap: var(--space-5);
	}

	.contact-item h3 {
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-muted);
		margin-bottom: var(--space-2);
	}

	.contact-item a {
		font-size: 1rem;
		word-break: break-all;
	}

	@media (max-width: 640px) {
		.involve-page {
			padding: var(--space-6) var(--space-4) var(--space-7);
		}
	}
</style>
