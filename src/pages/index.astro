---
import Layout from "../layouts/Layout.astro";
import PlatformCard from "../components/PlatformCard.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

interface PlatformHighlight {
	icon: string;
	title: string;
	description: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const whyBodyParagraphs = t<string[]>("pages.index.whyBody");
const platformHighlights = t<PlatformHighlight[]>(
	"pages.index.platformHighlights",
);
---

<Layout>
	<section class="hero" aria-label={t("pages.index.heroAria")}>
		<div class="hero-inner">
			<p class="hero-tagline">
				<strong>{t("pages.index.heroTaglineStrong")}</strong>
				<span>{` ${t("pages.index.heroTaglineRest")}`}</span>
			</p>
			<h1 class="hero-name display-title">
				{t("site.name")}
			</h1>
			<p class="hero-label">
				<span>{t("pages.index.heroLabelPrefix")}</span>
				<strong>{` ${t("pages.index.heroLabelEmphasis")}`}</strong>
			</p>
			<div class="hero-actions">
				<a href={localePath("/platform/", lang)} class="btn btn-primary"
					>{t("buttons.readPlatform")}</a
				>
				<a href={localePath("/about/", lang)} class="btn btn-secondary">
					{t("buttons.aboutMe")}
				</a>
			</div>
		</div>
	</section>

	<section class="section" aria-labelledby="platform-heading">
		<div class="section-inner">
			<h2 id="platform-heading" class="section-heading">
				{t("pages.index.platformHeading")}
			</h2>
			<div class="platform-grid">
				{
					platformHighlights?.map(item => (
						<PlatformCard
							title={item.title}
							description={item.description}
							icon={item.icon}
						/>
					))
				}
			</div>
			<div class="section-cta">
				<a href={localePath("/platform/", lang)} class="btn btn-primary"
					>{t("buttons.fullPlatform")}</a
				>
			</div>
		</div>
	</section>

	<section class="section" aria-label={t("pages.index.countdownAria")}>
		<div class="section-inner countdown-section">
			<div
				id="countdown"
				class="countdown"
				role="timer"
				data-label-open={t("countdown.open")}
				data-label-closed={t("countdown.closed")}
			>
				<p class="sr-only" aria-live="polite" id="countdown-sr">
					{t("pages.index.countdownSr")}
				</p>
				<p class="countdown-label">{t("countdown.label")}</p>
				<div class="countdown-timer" aria-hidden="true">
					<div class="countdown-unit">
						<span class="countdown-number" id="countdown-days"
							>--</span
						>
						<span class="countdown-text">{t("countdown.days")}</span
						>
					</div>
					<div class="countdown-unit">
						<span class="countdown-number" id="countdown-hours"
							>--</span
						>
						<span class="countdown-text"
							>{t("countdown.hours")}</span
						>
					</div>
					<div class="countdown-unit">
						<span class="countdown-number" id="countdown-minutes"
							>--</span
						>
						<span class="countdown-text"
							>{t("countdown.minutes")}</span
						>
					</div>
					<div class="countdown-unit">
						<span class="countdown-number" id="countdown-seconds"
							>--</span
						>
						<span class="countdown-text"
							>{t("countdown.seconds")}</span
						>
					</div>
				</div>
				<noscript><p>{t("pages.index.noscriptCountdown")}</p></noscript>
			</div>

		</div>
	</section>

	<section
		class="section section-alt poster-band"
		aria-labelledby="why-heading"
	>
		<div class="section-inner">
			<h2 id="why-heading" class="section-heading">
				{t("pages.index.whyHeading")}
			</h2>
			<div class="prose">
				{whyBodyParagraphs.map(p => <p>{p}</p>)}
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		padding: var(--space-10) var(--space-5) var(--space-10);
		text-align: left;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}

	.hero::before,
	.hero::after {
		content: "";
		position: absolute;
		inset: 0;
	}

	.hero::before {
		background: url(/daniel.webp) no-repeat;
		background-position-x: right;
		background-position-y: 20%;
		background-size: cover;
	}

	.hero::after {
		background: linear-gradient(
			rgba(86, 2, 22, 0.45),
			rgba(41, 39, 82, 0.65)
		);
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		margin: 0;
		padding: var(--space-6);
		background: rgba(41, 39, 82, 0.45);
		border-radius: var(--radius-2);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
	}

	.hero-label {
		font-size: clamp(1rem, 1vw + 0.55rem, 1.25rem);
		font-weight: 400;
		letter-spacing: 0.02em;
		color: var(--brand-lavender-light);
		margin-bottom: var(--space-6);
	}

	.hero-label strong {
		font-weight: 800;
	}

	.hero-name {
		font-size: clamp(3rem, 7vw + 1rem, 5rem);
		font-weight: 400;
		letter-spacing: normal;
		line-height: 1.05;
		margin-bottom: var(--space-3);
		color: var(--brand-white) !important;
	}

	.hero-tagline {
		font-size: clamp(1.125rem, 2vw + 0.25rem, 1.5rem);
		color: var(--brand-lavender-light);
		max-width: 36rem;
		margin: 0 0 var(--space-4);
		line-height: 1.5;
	}

	.hero-tagline strong {
		font-weight: 800;
	}

	.hero-tagline span {
		font-weight: 500;
	}

	.hero-actions {
		display: flex;
		gap: var(--space-3);
		justify-content: flex-start;
		flex-wrap: wrap;
	}

	.hero-actions .btn-primary {
		background: var(--brand-lavender-light);
		border-color: rgba(255, 255, 255, 0.36);
		color: var(--brand-navy) !important;
		font-weight: 700;
	}

	.hero-actions .btn-primary:hover {
		background: var(--brand-white);
		color: var(--brand-navy) !important;
	}

	.hero-actions .btn-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.5);
		color: var(--brand-white) !important;
		font-weight: 700;
	}

	.hero-actions .btn-secondary:hover {
		background: rgba(255, 255, 255, 0.15);
		color: var(--brand-white) !important;
	}

	.section {
		padding: var(--space-9) var(--space-5);
	}

	.section-alt {
		background: transparent;
		clip-path: polygon(0 10%, 100% 0, 100% 100%, 0 100%);
	}

	.section-inner {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.section-heading {
		font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
		margin-bottom: var(--space-4);
	}

	.section-lead {
		font-size: 1.0625rem;
		color: var(--color-muted);
		max-width: 56ch;
		margin-bottom: var(--space-7);
		line-height: 1.65;
	}

	.section-cta {
		margin-top: var(--space-7);
		text-align: center;
	}

	.platform-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
		gap: var(--space-5);
	}

	.prose p {
		margin-bottom: var(--space-4);
		line-height: 1.75;
		max-width: 65ch;
	}

	.prose p:last-child {
		margin-bottom: 0;
	}

	.countdown-section {
		text-align: center;
	}

	.countdown-label {
		font-size: 1.0625rem;
		color: var(--color-muted);
		margin-bottom: var(--space-4);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.countdown-timer {
		display: flex;
		justify-content: center;
		gap: var(--space-5);
		margin-bottom: var(--space-6);
		flex-wrap: wrap;
	}

	.countdown-unit {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-1);
		min-width: 4.5rem;
	}

	.countdown-number {
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 800;
		line-height: 1;
		color: var(--color-accent);
		font-variant-numeric: tabular-nums;
	}

	.countdown-text {
		font-size: 0.75rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 600;
	}

	@media (max-width: 480px) {
		.hero {
			padding: 0;
			display: block;
			text-align: center;
		}

		.hero::before,
		.hero::after {
			inset: 0 0 auto 0;
			height: 55svh;
		}

		.hero::before {
			background-size: cover;
			background-position: center 15%;
			transform: none;
		}

		.hero::after {
			inset: 0 0 auto 0;
		}

		.hero-inner {
			margin-top: 55svh;
			padding: var(--space-6) var(--space-4) var(--space-4);
			border-radius: 0;
			background: var(--color-bg);
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
		}

		.hero-tagline {
			color: var(--color-accent);
		}

		.hero-tagline span {
			color: var(--color-text);
		}

		.hero-name {
			color: var(--color-text) !important;
		}

		.hero-label {
			color: var(--color-muted);
		}

		.hero-actions .btn-primary {
			background: var(--color-accent);
			border-color: var(--color-accent);
			color: var(--color-on-accent) !important;
		}

		.hero-actions .btn-primary:hover {
			background: var(--color-accent-hover);
			border-color: var(--color-accent-hover);
			color: var(--color-on-accent) !important;
		}

		.hero-actions .btn-secondary {
			background: transparent;
			border-color: var(--color-border);
			color: var(--color-text) !important;
		}

		.hero-actions .btn-secondary:hover {
			background: var(--color-accent-soft);
			color: var(--color-text) !important;
		}
	}

	@media (max-width: 640px) {
		.section {
			padding: var(--space-7) var(--space-4);
		}

		.section-alt {
			clip-path: none;
		}
	}

	@media (max-width: 1700px) {
		.hero::before {
			background-size: 150%;
		}
	}
	@media (max-width: 1200px) {
		.hero::before {
			background-size: 160%;
		}
	}

	@media (max-width: 900px) {
		.hero::before {
			background-size: 175%;
		}
	}
</style>

<script>
	const VOTE_OPEN = new Date("2026-03-02T00:00:00-05:00").getTime();
	const VOTE_CLOSE = new Date("2026-03-07T00:00:00-05:00").getTime();

	function updateCountdown() {
		const now = Date.now();
		const countdown = document.getElementById("countdown");
		const label = document.querySelector(".countdown-label");
		const days = document.getElementById("countdown-days");
		const hours = document.getElementById("countdown-hours");
		const minutes = document.getElementById("countdown-minutes");
		const seconds = document.getElementById("countdown-seconds");

		if (!countdown || !label || !days || !hours || !minutes || !seconds)
			return;

		const openText = countdown.getAttribute("data-label-open") || "";
		const closedText = countdown.getAttribute("data-label-closed") || "";

		if (now >= VOTE_CLOSE) {
			label.textContent = closedText;
			days.textContent = "0";
			hours.textContent = "0";
			minutes.textContent = "0";
			seconds.textContent = "0";
			return;
		}

		if (now >= VOTE_OPEN) {
			label.textContent = openText;
			const remaining = VOTE_CLOSE - now;
			const d = Math.floor(remaining / (1000 * 60 * 60 * 24));
			const h = Math.floor(
				(remaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
			);
			const m = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
			const s = Math.floor((remaining % (1000 * 60)) / 1000);
			days.textContent = String(d);
			hours.textContent = String(h);
			minutes.textContent = String(m);
			seconds.textContent = String(s);
			return;
		}

		const remaining = VOTE_OPEN - now;
		const d = Math.floor(remaining / (1000 * 60 * 60 * 24));
		const h = Math.floor(
			(remaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
		);
		const m = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
		const s = Math.floor((remaining % (1000 * 60)) / 1000);
		days.textContent = String(d);
		hours.textContent = String(h);
		minutes.textContent = String(m);
		seconds.textContent = String(s);
	}

	updateCountdown();
	setInterval(updateCountdown, 1000);
</script>
