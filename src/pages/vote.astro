---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

interface VoteMethod {
	icon: string;
	title: string;
	body: string;
	note: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const methods = t<VoteMethod[]>("pages.vote.methods");
const eligibilityText = t<string[]>("pages.vote.eligibilityText");
---

<Layout title={t("pages.vote.title")} description={t("pages.vote.description")}>
	<section class="vote-page">
		<div class="vote-header poster-band">
			<h1>{t("pages.vote.heading")}</h1>
			<p class="vote-lead">{t("pages.vote.lead")}</p>
		</div>

		<div class="methods-grid">
			{
				methods.map(method => (
					<article class="method-card">
						<span class="method-icon" aria-hidden="true">{method.icon}</span>
						<h2>{method.title}</h2>
						<p>{method.body}</p>
						<p class="method-note">
							{method.note}
							{
								method.title.includes("Email") || method.title.includes("courriel") ? (
									<>
										{" "}
										<a href="mailto:elections@seuo-uosu.ca">elections@seuo-uosu.ca</a>
									</>
								) : null
							}
						</p>
					</article>
				))
			}
		</div>

		<div class="info-section poster-band">
			<h2>{t("pages.vote.eligibilityHeading")}</h2>
			{eligibilityText.map(text => <p>{text}</p>)}
		</div>

		<div class="vote-cta poster-band">
			<p>{t("pages.vote.ctaLead")}</p>
			<a href={localePath("/get-involved/", lang)} class="btn btn-primary"
				>{t("buttons.getInTouch")}</a
			>
		</div>
	</section>
</Layout>

<style>
	.vote-page {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-8) var(--space-5) var(--space-9);
	}

	.vote-header {
		margin-bottom: var(--space-8);
	}

	.vote-header h1 {
		margin-bottom: var(--space-3);
	}

	.vote-lead {
		font-size: 1.125rem;
		color: var(--color-muted);
		max-width: 56ch;
		line-height: 1.6;
	}

	.methods-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
		gap: var(--space-5);
		margin-bottom: var(--space-8);
	}

	.method-card {
		padding: var(--space-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-2);
		transition: border-color var(--dur-2) var(--ease-out);
	}

	.method-card:hover {
		border-color: var(--color-accent);
	}

	.method-icon {
		font-size: 2rem;
		display: block;
		margin-bottom: var(--space-3);
	}

	.method-card h2 {
		font-size: 1.25rem;
		margin-bottom: var(--space-3);
	}

	.method-card p {
		font-size: 0.9375rem;
		color: var(--color-muted);
		line-height: 1.65;
		margin-bottom: var(--space-3);
	}

	.method-card p:last-child {
		margin-bottom: 0;
	}

	.method-note {
		font-size: 0.875rem !important;
		opacity: 0.8;
	}

	.info-section {
		margin-bottom: var(--space-7);
		padding-bottom: var(--space-7);
		border-bottom: 1px solid var(--color-border);
	}

	.info-section.poster-band {
		padding: var(--space-6) var(--space-5);
		border-bottom: none;
	}

	.info-section:last-of-type {
		border-bottom: none;
	}

	.info-section h2 {
		font-size: 1.5rem;
		margin-bottom: var(--space-4);
	}

	.info-section p {
		font-size: 1rem;
		color: var(--color-muted);
		line-height: 1.65;
		max-width: 60ch;
	}

	.vote-cta {
		text-align: center;
		padding-top: var(--space-6);
	}

	.vote-cta.poster-band {
		padding: var(--space-6) var(--space-5);
	}

	.vote-cta p {
		color: var(--color-muted);
		margin: 0 auto var(--space-4);
	}

	@media (max-width: 640px) {
		.vote-page {
			padding: var(--space-6) var(--space-4) var(--space-7);
		}
	}
</style>
