---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

interface PlatformPoint {
	summary: string;
	detail?: string;
}

interface PlatformSection {
	id: string;
	title: string;
	icon: string;
	intro?: string[];
	points: PlatformPoint[];
	closing?: string[];
}

interface PlatformPreamble {
	title: string;
	paragraphs: string[];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const preamble = t<PlatformPreamble>("pages.platform.preamble");
const platform = t<PlatformSection[]>("pages.platform.sections");
---

<Layout
	title={t("pages.platform.title")}
	description={t("pages.platform.description")}
>
	<section class="platform-page">
		<div class="platform-header poster-band">
			<h1>{t("pages.platform.heading")}</h1>
			<p class="platform-lead">{t("pages.platform.lead")}</p>
		</div>

		<article class="preamble-section" aria-labelledby="preamble-heading">
			<h2 id="preamble-heading">{preamble.title}</h2>
			{preamble.paragraphs.map(p => <p class="section-intro">{p}</p>)}
		</article>

		{
			platform.map(section => (
				<article
					class="platform-section"
					id={section.id}
					aria-labelledby={`heading-${section.id}`}
				>
					<h2 id={`heading-${section.id}`}>
						<span class="section-icon" aria-hidden="true">
							{section.icon}
						</span>
						{section.title}
					</h2>
					{section.intro &&
						section.intro.map(p => (
							<p class="section-intro">{p}</p>
						))}
					{section.points.length > 0 && (
						<ul class="platform-list">
							{section.points.map(point =>
								point.detail ? (
									<li>
										<details class="point-details">
											<summary>{point.summary}</summary>
											<p class="point-detail">
												{point.detail}
											</p>
										</details>
									</li>
								) : (
									<li>{point.summary}</li>
								),
							)}
						</ul>
					)}
					{section.closing &&
						section.closing.map(p => (
							<p class="section-closing">{p}</p>
						))}
				</article>
			))
		}

		<section
			class="suggest-section poster-band"
			aria-label={t("pages.platform.suggestAria")}
		>
			<h2>{t("pages.platform.suggestHeading")}</h2>
			<p>{t("pages.platform.suggestBody")}</p>
			<a
				href="mailto:vote@danielthorp.com?subject=Platform Idea"
				class="btn btn-secondary">{t("buttons.suggestIdea")}</a
			>
		</section>

		<section
			class="platform-cta poster-band"
			aria-label={t("pages.platform.backTopAria")}
		>
			<a href={localePath("/", lang)} class="btn btn-primary"
				>{t("buttons.backHome")}</a
			>
		</section>
	</section>
</Layout>

<style>
	.platform-page {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-8) var(--space-5) var(--space-9);
	}

	.platform-header {
		margin-bottom: var(--space-8);
	}

	.platform-header h1 {
		margin-bottom: var(--space-3);
	}

	.platform-lead {
		font-size: 1.125rem;
		color: var(--color-muted);
		max-width: 56ch;
		line-height: 1.6;
	}

	.preamble-section {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-7);
		border-bottom: 1px solid var(--color-border);
	}

	.preamble-section h2 {
		margin-bottom: var(--space-4);
	}

	.section-intro {
		color: var(--color-text);
		line-height: 1.7;
		max-width: 65ch;
		margin-bottom: var(--space-3);
	}

	.section-closing {
		color: var(--color-text);
		line-height: 1.7;
		max-width: 65ch;
		margin-top: var(--space-3);
		font-weight: 500;
	}

	.platform-section {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-7);
		border-bottom: 1px solid var(--color-border);
	}

	.platform-section:last-of-type {
		border-bottom: none;
	}

	.platform-section h2 {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
	}

	.section-icon {
		font-size: 1.5rem;
	}

	.platform-list {
		padding-left: var(--space-5);
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.platform-list li {
		line-height: 1.65;
		color: var(--color-text);
		max-width: 60ch;
	}

	.platform-list li::marker {
		color: var(--color-accent);
	}

	.platform-list li:has(.point-details) {
		list-style: none;
	}

	.point-details {
		cursor: pointer;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-1);
		padding: var(--space-3) var(--space-4);
		transition: border-color var(--dur-2) var(--ease-out),
			background var(--dur-2) var(--ease-out);
	}

	.point-details:hover {
		border-color: var(--color-accent);
		background: rgba(255, 255, 255, 0.3);
	}

	.point-details summary {
		list-style: none;
		display: flex;
		align-items: baseline;
		gap: var(--space-2);
		font-weight: 600;
	}

	.point-details summary::-webkit-details-marker {
		display: none;
	}

	.point-details summary::before {
		content: "▸";
		font-size: 0.85rem;
		color: var(--color-accent);
		transition: transform var(--dur-2) var(--ease-out);
		flex-shrink: 0;
		display: inline-block;
	}

	.point-details[open] summary::before {
		transform: rotate(90deg);
	}

	.point-details[open] {
		background: rgba(255, 255, 255, 0.3);
	}

	.point-detail {
		margin-top: var(--space-3);
		padding-top: var(--space-3);
		border-top: 1px solid var(--color-border);
		font-size: 0.875rem;
		color: var(--color-muted);
		line-height: 1.7;
		padding-left: 0;
		max-width: 58ch;
		font-weight: 500;
	}

	.suggest-section {
		text-align: center;
		padding: var(--space-6) var(--space-5);
		margin-bottom: var(--space-7);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-2);
	}

	.suggest-section h2 {
		margin-bottom: var(--space-2);
	}

	.suggest-section p {
		color: var(--color-muted);
		margin: 0 auto var(--space-5);
	}

	.platform-cta {
		text-align: center;
		padding-top: var(--space-6);
	}

	@media (max-width: 640px) {
		.platform-page {
			padding: var(--space-6) var(--space-4) var(--space-7);
		}
	}
</style>
