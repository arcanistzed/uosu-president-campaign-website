---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

interface AboutRole {
	title: string;
	period: string;
	points?: string[];
	summary?: string;
}

interface AboutSection {
	id: string;
	icon: string;
	title: string;
	intro?: string;
	roles: AboutRole[];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sections = t<AboutSection[]>("pages.about.sections");
---

<Layout
	title={t("pages.about.title")}
	description={t("pages.about.description")}
>
	<section class="about-page">
		<div class="about-header poster-band">
			<h1>{t("pages.about.heading")}</h1>
			<p class="about-lead">{t("pages.about.lead")}</p>
		</div>

		{
			sections.map(section => (
				<article class="about-section" id={section.id}>
					<h2>
						<span class="section-icon" aria-hidden="true">
							{section.icon}
						</span>
						{section.title}
					</h2>
					{section.intro && (
						<p class="section-intro">{section.intro}</p>
					)}

					{section.roles.map(role => (
						<div class="role-card">
							<h3>{role.title}</h3>
							<p class="role-period">{role.period}</p>
							{role.points && (
								<ul class="role-points">
									{role.points.map(point => (
										<li>{point}</li>
									))}
								</ul>
							)}
							{role.summary && (
								<p class="role-summary">{role.summary}</p>
							)}
						</div>
					))}
				</article>
			))
		}

		<div class="about-cta poster-band">
			<a href={localePath("/platform/", lang)} class="btn btn-primary"
				>{t("buttons.readPlatform")}</a
			>
			<a
				href="https://vote.seuo-uosu.com"
				class="btn btn-secondary"
				target="_blank"
				rel="noopener">{t("buttons.howToVote")}</a
			>
		</div>
	</section>
</Layout>

<style>
	.about-page {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-8) var(--space-5) var(--space-9);
	}

	.about-header {
		margin-bottom: var(--space-7);
	}

	.about-header h1 {
		margin-bottom: var(--space-3);
	}

	.about-lead {
		font-size: 1.125rem;
		color: var(--color-muted);
		max-width: 56ch;
		line-height: 1.6;
	}

	.about-section {
		margin-bottom: var(--space-8);
		padding-bottom: var(--space-7);
		border-bottom: 1px solid var(--color-border);
	}

	.about-section:last-of-type {
		border-bottom: none;
	}

	.about-section h2 {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-4);
	}

	.section-icon {
		font-size: 1.5rem;
	}

	.section-intro {
		font-size: 1rem;
		color: var(--color-muted);
		line-height: 1.65;
		max-width: 60ch;
		margin-bottom: var(--space-5);
	}

	.role-card {
		margin-bottom: var(--space-5);
		padding: var(--space-4) var(--space-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-2);
	}

	.role-card:last-child {
		margin-bottom: 0;
	}

	.role-card h3 {
		font-size: 1.0625rem;
		font-weight: 600;
		margin-bottom: var(--space-1);
	}

	.role-period {
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin-bottom: var(--space-3);
	}

	.role-summary {
		font-size: 0.9375rem;
		color: var(--color-muted);
		line-height: 1.65;
		max-width: 60ch;
	}

	.role-points {
		padding-left: var(--space-5);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.role-points li {
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--color-text);
		max-width: 60ch;
	}

	.role-points li::marker {
		color: var(--color-accent);
	}

	.about-cta {
		display: flex;
		gap: var(--space-3);
		justify-content: center;
		flex-wrap: wrap;
		padding-top: var(--space-6);
	}

	@media (max-width: 640px) {
		.about-page {
			padding: var(--space-6) var(--space-4) var(--space-7);
		}

		.role-card {
			padding: var(--space-3) var(--space-4);
		}
	}
</style>
