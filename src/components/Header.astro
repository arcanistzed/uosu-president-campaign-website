---
import {
	getLangFromUrl,
	useTranslations,
	localePath,
	switchLangPath,
} from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const links = [
	{ href: localePath("/", lang), label: t("nav.home") },
	{ href: localePath("/platform/", lang), label: t("nav.platform") },
	{ href: localePath("/about/", lang), label: t("nav.about") },
	{ href: localePath("/faq/", lang), label: t("nav.faq") },
];

const switchHref = switchLangPath(currentPath, lang);
const switchLabel = t<string>("lang.switch");
---

<header class="site-header">
	<nav class="nav" aria-label={t("header.navAria")}>
		<a
			href={localePath("/", lang)}
			class="nav-logo"
			aria-label={t("header.homeAria")}
		>
			<strong>{t("site.name")}</strong>
			<span class="nav-tag">{t("site.tagline")}</span>
		</a>
		<button
			class="nav-toggle"
			aria-expanded="false"
			aria-controls="nav-menu"
			aria-label={t("header.menuAria")}
			type="button"
		>
			<span class="nav-toggle-icon" aria-hidden="true">☰</span>
		</button>
		<ul class="nav-links" id="nav-menu" role="list">
			{
				links.map(({ href, label }) => (
					<li>
						<a
							href={href}
							class:list={[
								"nav-link",
								{ active: currentPath === href },
							]}
							aria-current={
								currentPath === href ? "page" : undefined
							}
						>
							{label}
						</a>
					</li>
				))
			}
			<li class="lang-switch-mobile">
				<a
					href={switchHref}
					class="lang-switch"
					aria-label={t("lang.switchTo", { language: switchLabel })}
					>{switchLabel}</a
				>
			</li>
		</ul>
		<a
			href={switchHref}
			class="lang-switch lang-switch-desktop"
			aria-label={t("lang.switchTo", { language: switchLabel })}
			>{switchLabel}</a
		>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--color-bg) 88%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--color-border);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--page-max);
		margin: 0 auto;
		padding: var(--space-4) var(--space-5);
	}

	.nav-logo {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.1em;
		color: var(--color-text);
		text-decoration: none;
		font-size: 1.125rem;
		font-weight: 800;
	}

	.nav-logo:hover {
		text-decoration: none;
		color: var(--color-text);
	}

	.nav-tag {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-muted);
	}

	.nav-links {
		display: flex;
		gap: var(--space-5);
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.nav-link {
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 600;
		text-decoration: none;
		padding: var(--space-1) 0;
		border-bottom: 2px solid transparent;
		transition:
			color var(--dur-fast) var(--ease-out),
			border-color var(--dur-fast) var(--ease-out);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-text);
		text-decoration: none;
	}

	.nav-link.active {
		border-bottom-color: var(--color-banner);
	}

	.lang-switch {
		color: var(--color-text);
		font-size: 0.8125rem;
		font-weight: 700;
		text-decoration: none;
		padding: var(--space-1) var(--space-3);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-1);
		transition:
			color var(--dur-fast) var(--ease-out),
			border-color var(--dur-fast) var(--ease-out);
		white-space: nowrap;
	}

	.lang-switch:hover {
		color: var(--color-banner);
		border-color: var(--color-banner);
		text-decoration: none;
	}

	.nav-toggle {
		display: none;
		background: none;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-1);
		padding: var(--space-1) var(--space-2);
		color: var(--color-text);
		font-size: 1.25rem;
		cursor: pointer;
		line-height: 1;
	}

	.lang-switch-mobile {
		display: none;
	}

	@media (max-width: 640px) {
		.nav {
			padding: var(--space-3) var(--space-4);
			flex-wrap: wrap;
		}

		.nav-toggle {
			display: flex;
			align-items: center;
			order: 2;
		}

		.lang-switch-desktop {
			display: none;
		}

		.lang-switch-mobile {
			display: list-item;
			padding-top: var(--space-2);
			border-top: 1px solid var(--color-border);
		}

		.nav-links {
			display: none;
			flex-direction: column;
			gap: 0;
			width: 100%;
			order: 3;
			padding-top: var(--space-3);
		}

		.nav-links.open {
			display: flex;
		}

		.nav-link {
			display: block;
			padding: var(--space-2) 0;
			border-bottom: none;
		}
	}
</style>

<script>
	const toggle = document.querySelector(".nav-toggle");
	const menu = document.getElementById("nav-menu");
	if (toggle && menu) {
		toggle.addEventListener("click", () => {
			const expanded = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!expanded));
			menu.classList.toggle("open");
			const icon = toggle.querySelector(".nav-toggle-icon");
			if (icon) icon.textContent = expanded ? "☰" : "✕";
		});
	}
</script>
