---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<p class="footer-text">
			&copy; {year} Daniel Thorp. Campaign for UOSU President.
		</p>
		<div class="footer-links">
			<a
				href="https://instagram.com/daniel.thorp.seuo.uosu"
				rel="noopener noreferrer"
				aria-label="Instagram">Instagram</a
			>
			<span class="footer-sep" aria-hidden="true">·</span>
			<a href="mailto:vote@danielthorp.com">vote@danielthorp.com</a>
			<span class="footer-sep" aria-hidden="true">·</span>
			<a href="https://danielthorp.com" rel="noopener noreferrer"
				>danielthorp.com</a
			>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-9);
		padding: var(--space-6) var(--space-5);
	}

	.footer-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.footer-text {
		font-size: 0.8125rem;
		color: var(--color-muted);
	}

	.footer-text a {
		color: var(--color-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.footer-text a:hover {
		color: var(--color-text);
	}

	.footer-links {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		flex-wrap: wrap;
		font-size: 0.8125rem;
	}

	.footer-links a {
		color: var(--color-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.footer-links a:hover {
		color: var(--color-text);
	}

	.footer-sep {
		color: var(--color-muted);
		opacity: 0.5;
	}

	@media (max-width: 640px) {
		.footer-inner {
			flex-direction: column;
			text-align: center;
		}

		.footer-links {
			justify-content: center;
		}
	}
</style>
