---
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<p class="footer-text">
			&copy; {year}
			{t("footer.copyright")}
		</p>
		<div class="footer-links">
			<a
				class="instagram-link"
				href="https://instagram.com/daniel.thorp.seuo.uosu"
				rel="noopener noreferrer"
				aria-label={t("footer.instagram")}
			>
				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
					focusable="false"
					class="social-icon"
				>
					<path
						fill="currentColor"
						d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9ZM17 6.75a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"
					></path>
				</svg>
				<span>{t("footer.instagram")}</span>
			</a
			>
			<span class="footer-sep" aria-hidden="true">·</span>
			<a href="mailto:vote@danielthorp.com">vote@danielthorp.com</a>
			<span class="footer-sep" aria-hidden="true">·</span>
			<a href={localePath("/faq/", lang)}>{t("footer.faq")}</a>
			<span class="footer-sep" aria-hidden="true">·</span>
			<a href="https://danielthorp.com" rel="noopener noreferrer"
				>danielthorp.com</a
			>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid color-mix(in srgb, var(--color-border) 90%, var(--color-text) 10%);
		margin-top: var(--space-9);
		padding: var(--space-6) var(--space-5);
	}

	.footer-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.footer-text {
		font-size: 0.8125rem;
		color: var(--color-muted);
	}

	.footer-text a {
		color: var(--color-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.footer-text a:hover {
		color: var(--color-accent);
	}

	.footer-links {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		flex-wrap: wrap;
		font-size: 0.8125rem;
	}

	.footer-links a {
		color: var(--color-muted);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.instagram-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.social-icon {
		width: 0.95em;
		height: 0.95em;
		flex: 0 0 auto;
	}

	.footer-links a:hover {
		color: var(--color-accent);
	}

	.footer-sep {
		color: var(--color-muted);
		opacity: 0.5;
	}

	@media (max-width: 640px) {
		.footer-inner {
			flex-direction: column;
			text-align: center;
		}

		.footer-links {
			justify-content: center;
		}
	}
</style>
