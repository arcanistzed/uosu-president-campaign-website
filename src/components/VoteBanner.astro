---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<aside class="vote-banner" aria-label={t("banner.title")}>
	<div class="vote-banner-inner">
		<div class="vote-banner-content">
			<p class="vote-banner-title">{t("banner.title")}</p>
			<p class="vote-banner-body">{t("banner.text")}</p>
		</div>
	</div>
</aside>

<style>
	.vote-banner {
		background: var(--color-banner);
		color: var(--color-on-banner);
		padding: var(--space-3) var(--space-5);
	}

	.vote-banner-inner {
		max-width: var(--page-max);
		margin: 0 auto;
	}

	.vote-banner-content {
		display: grid;
		gap: var(--space-1);
	}

	.vote-banner-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: 0.02em;
	}

	.vote-banner-body {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.5;
		max-width: 72ch;
	}

	@media (max-width: 640px) {
		.vote-banner {
			padding: var(--space-2) var(--space-4);
		}
	}
</style>
