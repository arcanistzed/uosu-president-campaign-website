---
import { getLangFromUrl, useTranslations, localePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<aside class="vote-banner" aria-label={t("banner.text")}>
	<div class="vote-banner-inner">
		<a
			href="https://vote.seuo-uosu.com"
			class="vote-banner-link"
			target="_blank"
			rel="noopener"><strong>🗳️ {t("banner.text")}</strong></a
		>
	</div>
</aside>

<style>
	.vote-banner {
		background: var(--color-banner);
		color: var(--color-on-banner);
		padding: var(--space-3) var(--space-5);
	}

	.vote-banner-inner {
		max-width: var(--page-max);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.vote-banner-link {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-on-banner);
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: var(--space-1) var(--space-4);
		border: 2px solid rgba(255, 255, 255, 0.4);
		border-radius: var(--radius-round);
		white-space: nowrap;
		transition:
			background var(--dur-2) var(--ease-out),
			border-color var(--dur-2) var(--ease-out);
	}

	.vote-banner-link:hover {
		background: rgba(255, 255, 255, 0.15);
		border-color: rgba(255, 255, 255, 0.7);
		color: var(--color-on-banner);
	}

	@media (max-width: 640px) {
		.vote-banner {
			padding: var(--space-2) var(--space-4);
		}
	}
</style>
