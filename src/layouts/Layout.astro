---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VoteBanner from "../components/VoteBanner.astro";
import "../styles/tokens.css";
import "../styles/base.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Vote Daniel Thorp — UOSU President",
	description = "Daniel Thorp is running for President of the University of Ottawa Students' Union. Learn about his platform and vision for students.",
} = Astro.props;

const canonicalURL = new URL(
	Astro.url.pathname,
	"https://vote.danielthorp.com",
);
const pageTitle =
	title === "Vote Daniel Thorp — UOSU President"
		? title
		: `${title} · Vote Daniel Thorp`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="author" content="Daniel Thorp" />
		<meta name="generator" content={Astro.generator} />

		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Vote Daniel Thorp" />
		<!-- TODO: Replace with actual OG image once designed (1200×630px) -->
		<meta
			property="og:image"
			content="https://vote.danielthorp.com/og-image.png"
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta
			name="twitter:image"
			content="https://vote.danielthorp.com/og-image.png"
		/>

		<link rel="manifest" href="/manifest.json" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Yeseva+One&display=swap"
			rel="stylesheet"
		/>

		<!-- Favicon — TODO: Replace with actual favicon assets -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>

		<!-- Theme color -->
		<meta
			name="theme-color"
			content="#1a1840"
			media="(prefers-color-scheme: dark)"
		/>
		<meta
			name="theme-color"
			content="#9f9cd8"
			media="(prefers-color-scheme: light)"
		/>

		<title>{pageTitle}</title>
	</head>

	<body>
		<div class="cloud-bg" aria-hidden="true"></div>
		<a href="#content" class="skip-link">Skip to content</a>
		<VoteBanner />
		<Header />
		<main id="content">
			<slot />
		</main>
		<Footer />
	</body>
</html>
