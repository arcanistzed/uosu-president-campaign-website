---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VoteBanner from "../components/VoteBanner.astro";
import "../styles/tokens.css";
import "../styles/base.css";
import { getLangFromUrl, switchLangPath, useTranslations } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const defaultTitle = t<string>("layout.defaultTitle");
const defaultDescription = t<string>("layout.defaultDescription");

const { title = defaultTitle, description = defaultDescription } = Astro.props;

const canonicalURL = Astro.url;
const pageTitle =
	title === defaultTitle
		? title
		: `${title} · ${t<string>("layout.titleSuffix")}`;

const alternatePath = switchLangPath(Astro.url.pathname, lang);
const alternateURL = new URL(alternatePath, "https://vote.danielthorp.com");
const alternateLang = lang === "en" ? "fr" : "en";
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="author" content={t("layout.author")} />
		<meta name="generator" content={Astro.generator} />

		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang={alternateLang} href={alternateURL} />
		<link rel="alternate" hreflang={lang} href={canonicalURL} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content={t("layout.ogSiteName")} />
		<meta
			property="og:image"
			content="https://vote.danielthorp.com/og-image.png"
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta
			name="twitter:image"
			content="https://vote.danielthorp.com/og-image.png"
		/>

		<link rel="manifest" href="/manifest.json" />

		<link
			rel="preload"
			href="/fonts/Garet-Book.woff"
			as="font"
			type="font/woff"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Garet-Heavy.woff"
			as="font"
			type="font/woff"
			crossorigin
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Yeseva+One&display=swap"
			rel="stylesheet"
		/>

		<script
			is:inline
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-PL71KBEP9H"
		></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());
			gtag("config", "G-PL71KBEP9H");
		</script>

		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" href="/favicon.png" />

		<meta
			name="theme-color"
			content="#9f9cd8"
			media="(prefers-color-scheme: dark)"
		/>
		<meta
			name="theme-color"
			content="#9f9cd8"
			media="(prefers-color-scheme: light)"
		/>

		<title>{pageTitle}</title>
	</head>

	<body>
		<div class="cloud-bg" aria-hidden="true"></div>
		<a href="#content" class="skip-link">{t("layout.skipToContent")}</a>
		<VoteBanner />
		<Header />
		<main id="content">
			<slot />
		</main>
		<Footer />
	</body>
</html>
